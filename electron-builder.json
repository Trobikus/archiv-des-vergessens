{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",

  "appId": "com.grimoire.archiv-des-vergessens",
  "productName": "Archiv des Vergessens",
  "copyright": "Copyright © 2026 Grimoire Interactive",

  "directories": {
    "output": "release",
    "buildResources": "."
  },

  "files": [
    "dist/**/*",
    "electron/main.cjs",
    "preload.js",
    "package.json"
  ],

  "extraResources": [
    {
      "from": "icon.ico",
      "to": "icon.ico"
    }
  ],

  "win": {
    "icon": "icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "Archiv-des-Vergessens-Setup-${version}.exe",
    "publisherName": "Grimoire Interactive",
    "verifyUpdateCodeSignature": false
  },

  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Archiv des Vergessens",
    "installerIcon": "icon.ico",
    "uninstallerIcon": "icon.ico",
    "installerHeaderIcon": "icon.ico",
    "installerHeader": "electron/installer/installerHeader.bmp",
    "installerSidebar": "electron/installer/installerSidebar.bmp",
    "uninstallerSidebar": "electron/installer/installerSidebar.bmp",
    "deleteAppDataOnUninstall": false,
    "menuCategory": "Grimoire Interactive",
    "runAfterFinish": true,
    "installerLanguages": ["de_DE", "en_US"],
    "language": "1031"
  },

  "publish": {
    "provider": "github",
    "owner": "Trobikus",
    "repo": "archiv-des-vergessens",
    "releaseType": "release",
    "private": false
  },

  "compression": "maximum",
  "removePackageScripts": true,

  "electronVersion": "31.7.7"
}
