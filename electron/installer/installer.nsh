; Custom styling for Modern UI (MUI2) to make the installer match the dark game theme
!define MUI_BGCOLOR "0E0C12"                 ; Dark purple-black background
!define MUI_TEXTCOLOR "FFFFFF"               ; White text for headings and labels
!define MUI_LICENSEPAGE_BGCOLOR "17141D"     ; Dark background for the license text area
!define MUI_LICENSEPAGE_TEXTCOLOR "E2D5C3"   ; Beige text for license text
!define MUI_DIRECTORYPAGE_BGCOLOR "17141D"   ; Dark background for directory text box
!define MUI_INSTFILESPAGE_COLORS "E2D5C3 17141D" ; Beige text on dark background for the install log
