{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArchivDesVergessens",
  "version": "1.0.13",
  "identifier": "com.grimoire.archivdesvergessens",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Archiv des Vergessens - Launcher",
        "label": "launcher",
        "url": "/launcher.html",
        "width": 1000,
        "height": 400,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": true
      },
      {
        "title": "Archiv des Vergessens",
        "label": "main",
        "url": "/index.html",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "createUpdaterArtifacts": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
