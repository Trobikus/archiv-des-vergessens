{
  "name": "archiv-des-vergessens",
  "version": "1.0.9",
  "description": "Archiv des Vergessens – Ein episches Idle-RPG über Erinnerung, Vergessen und die Macht der Mneme.",
  "private": true,
  "type": "module",
  "author": {
    "name": "Grimoire Interactive"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:local": "powershell -Command \"$env:TAURI_SIGNING_PRIVATE_KEY=(Get-Content updater.key -Raw); $env:TAURI_SIGNING_PRIVATE_KEY_PASSWORD=''; tauri build\""
  },
  "dependencies": {
    "htm": "^3.1.1",
    "preact": "^10.19.3"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.5",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
